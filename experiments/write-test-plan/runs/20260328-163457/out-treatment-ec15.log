cy. Mocking any component hides real bottlenecks. You need all four steps (embedding → search → rerank → return) executing against real services. **Workflow** level."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":13511,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13511},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d4bde30a-82ea-44d8-b71b-232be058ffa5","uuid":"5290ee4d-91a0-4bf9-9c25-cd0acbc76dc9"}
