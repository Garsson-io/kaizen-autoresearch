 a review_flag field set to True, (3) report describes the breaking change reason. Test with non-breaking bump to ensure PR is still created and flag is False. Check that flag is present in all output formats (JSON, CLI).","plan_consistent":true,"level_probabilities":{"Unit":0.7,"Integration":0.2,"System":0.08,"Agentic":0.01,"Workflow":0.01}}]}},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":12668,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12668},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0e22490f-d60c-4dd8-a74e-6dc13fbca77e","uuid":"3de8e685-9156-4c8a-bbd8-2899c4577894"}
