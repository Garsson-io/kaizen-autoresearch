figuration.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.74,"Integration":0.22,"System":0.02,"Agentic":0.01,"Workflow":0.01}},{"behavior_id":4,"description":"Explanation for sarcastic review identifies negative intent despite positive surface words.","minimum_level":"Agentic","justification":"Sarcasm interpretation is model-judgment dependent. Deterministic mocks cannot validate true intent understanding and would hide real failures.","test_description":"Use real model inference on sarcasm examples like \"Great, another broken feature.\" Check explanation explicitly indicates negative intent/frustration and cites contradiction between positive wording and negative context.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.01,"Integration":0.07,"System":0.02,"Agentic":0.88,"Workflow":0.02}},{"behavior_id":5,"description":"Service returns score and explanation together, and explanation aligns with the same sentiment direction as score.","minimum_level":"Agentic","justification":"Response bundling itself is integration-level, but real failure risk includes model-generated explanation polarity drifting from computed score. Mocking the explainer can mask this inconsistency.","test_description":"Invoke the real service path with real keyword scorer + real explanation generation. Assert both fields are present in one response and explanation polarity (parsed via a simple rubric/checker) matches returned score direction.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.05,"Integration":0.4,"System":0.03,"Agentic":0.5,"Workflow":0.02}}]}
