ation at 0.65 for the full in-process pipeline and System at 0.25 if stdin needs a subprocess. Behavior 6 is Unit-dominant at 0.80 as a comparative parser test, with minimal integration or system-level concerns.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":9667,"cache_read_input_tokens":3199,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9667},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5371ae57-3e36-4059-88c6-d290368569f5","uuid":"95f783bf-0e53-4f33-90da-d5cbe06a59a5"}
