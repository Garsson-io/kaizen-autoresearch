mplement-stage function with an artifact dict that contains some pre-existing entries but no 'grounding' key (LLM mocked). Assert that a 'plan' key is present and non-empty in the resulting artifact dict. Assert that all pre-existing artifact keys retain their original values and no new unexpected keys are introduced.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.75,"Integration":0.18,"System":0.02,"Agentic":0.03,"Workflow":0.02}}]},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":9641,"cache_read_input_tokens":3199,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9641},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cae73829-3f97-430e-9d01-73c607914de8","uuid":"efd5e2b6-485b-433b-94f8-56753ebf1269"}
