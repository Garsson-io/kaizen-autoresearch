osure guarantee ('second response replaces the first — customer never sees rejected draft').","test_description":"Run end-to-end chat turn with real model calls through initial + regeneration path on a canary prompt; capture customer-visible output and event log; assert only regenerated response is emitted while first draft is retained only as internal/audit record.","plan_consistent":true,"plan_consistent_note":"Assertion covers sequential agentic pipeline behavior, matching Workflow.","level_probabilities":{"Unit":0.01,"Integration":0.12,"System":0.02,"Agentic":0.35,"Workflow":0.5}}]}
