ities":{"Unit":0.02,"Integration":0.23,"System":0.6,"Agentic":0.1,"Workflow":0.05}},{"behavior_id":6,"description":"The moderation decision for a borderline image is consistent when the same image is submitted multiple times within a short window.","minimum_level":"Workflow","justification":"This requires repeated agentic evaluations over time plus stateful pipeline behavior (cache/idempotency/windowing). A single-call agentic test is insufficient; consistency failure appears across a sequence of submissions (MULTI-STEP + LLM-DEP).","test_description":"Submit the same borderline image N times within the configured short window through the full moderation path using the real vision model, then assert the final moderation outcome is stable across attempts (or consistently served from the same cached decision).","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0,"Integration":0.05,"System":0.1,"Agentic":0.35,"Workflow":0.5}}]}
