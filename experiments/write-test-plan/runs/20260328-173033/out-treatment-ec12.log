fter retries.","plan_consistent":true,"level_probabilities":{"Unit":0.35,"Integration":0.55,"System":0.1,"Agentic":0,"Workflow":0}},{"behavior_id":5,"description":"Rows successfully written to PostgreSQL are not duplicated if the pipeline is restarted mid-batch.","minimum_level":"Integration","justification":"Idempotency and exactly-once semantics depend on real database constraints, transaction semantics, and state tracking across process boundaries. Mocking PostgreSQL hides duplicate-detection failures, lost checkpoints, or missing uniqueness constraints. Only a real database can verify that rows 1–N and rows (N+1)–total both complete without duplicates.","test_description":"Integration test that loads a CSV with 500,000 rows into a test PostgreSQL database, runs the pipeline to completion on rows 1–250,000, stops the pipeline mid-batch, restarts it to process rows 1–500,000, and verifies: (1) all 500,000 rows appear in the database, (2) no row is duplicated, (3) row uniqueness is enforced (via composite key or unique constraint).","plan_consistent":true,"level_probabilities":{"Unit":0.05,"Integration":0.9,"System":0.05,"Agentic":0,"Workflow":0}}]},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":13637,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13637},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7c0eb23d-0e4d-4b12-beca-ab106f39afe3","uuid":"71ef5aae-990b-4bb2-a9b1-285bf676130c"}
