lan_consistent_note":null,"level_probabilities":{"Unit":0.03,"Integration":0.22,"System":0.75,"Agentic":0.0,"Workflow":0.0}},{"behavior_id":4,"description":"The counts in the report match the actual change history of the repository being analyzed.","minimum_level":"System","justification":"Correctness depends on end-to-end interaction with real git history traversal and CLI execution. Mocking history APIs can hide discrepancies in revision selection and status parsing.","test_description":"Build a real repo history with known operations across commits (add, modify, rename, delete), run the CLI for the intended analysis scope, and assert reported totals per category exactly match the known ground truth.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.01,"Integration":0.12,"System":0.87,"Agentic":0.0,"Workflow":0.0}},{"behavior_id":5,"description":"The output is identical whether the changes being analyzed are staged or unstaged.","minimum_level":"System","justification":"This depends on real index vs working-tree semantics from Git. Pure mocks can accidentally normalize both paths and miss divergence bugs.","test_description":"In a real temp repo, create equivalent change sets in two scenarios: (A) staged changes and (B) unstaged changes. Run CLI in both scenarios and assert structured stdout is identical.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.01,"Integration":0.19,"System":0.8,"Agentic":0.0,"Workflow":0.0}}]}
