y key constraints don't exist, or restart logic doesn't correctly identify already-written rows. Must verify against a real (or test) database schema to catch transaction and constraint issues.","test_description":"Insert rows into test PostgreSQL via pipeline, simulate mid-batch restart (truncate log or resume from checkpoint), re-run pipeline, query database to verify total row count matches expected (no duplicates), and unique constraints hold","plan_consistent":true,"level_probabilities":{"Unit":0,"Integration":0.8,"System":0.15,"Agentic":0,"Workflow":0.05}}]},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":13384,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13384},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"99b13226-56b9-4493-bf71-a7c40010ac20","uuid":"88bebc0f-bd3d-4dc8-a611-c056639e8036"}
