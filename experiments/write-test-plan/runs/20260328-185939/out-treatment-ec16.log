ather than halting entirely. Finally, duplicate findings—where multiple rules flag the same issue on the same line—should be consolidated into a single entry in the output.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":13451,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13451},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e3713f87-6be9-4a98-8428-c5a68cbc7c1a","uuid":"a8ec2fc1-bd00-4451-b048-0e80620812f3"}
