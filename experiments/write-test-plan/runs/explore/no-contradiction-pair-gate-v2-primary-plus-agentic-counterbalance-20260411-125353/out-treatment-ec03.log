e":null,"level_probabilities":{"Unit":0.04,"Integration":0.21,"System":0.75,"Agentic":0.0,"Workflow":0.0}},{"behavior_id":4,"description":"The counts in the report match the actual change history of the repository being analyzed.","minimum_level":"System","justification":"This validates end-to-end correctness against real repository history semantics, requiring actual commits, renames, deletions, and modifications interpreted by git and the CLI together.","test_description":"Build a real repo history with known adds/deletes/renames/modifies across multiple commits, run the CLI over the target range, and assert exact category counts match the constructed history.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.01,"Integration":0.09,"System":0.9,"Agentic":0.0,"Workflow":0.0}},{"behavior_id":5,"description":"The output is identical whether the changes being analyzed are staged or unstaged.","minimum_level":"System","justification":"Requires real index vs working-tree states and how git exposes each via commands; this is OS/filesystem + subprocess behavior, not just local function logic.","test_description":"In a real temp repo, create identical change sets once staged and once unstaged, run the CLI in both scenarios, and assert structured stdout is identical.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.02,"Integration":0.18,"System":0.8,"Agentic":0.0,"Workflow":0.0}}]}
