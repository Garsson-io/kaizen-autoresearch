Workflow":0.06}},{"behavior_id":5,"description":"When the email delivery service is unreachable, the generated report is saved to a local file and delivery is retried on the next scheduled run.","minimum_level":"Integration","justification":"Core failure is state handoff across modules/runs: send failure -> local persistence -> next-run retry. This can be reproduced with an in-process failing email adapter plus local filesystem fixture; real network outage mechanics are not required. System rejected because behavior text requires fallback/retry logic correctness, not provider-specific transport behavior.","test_description":"First run: fake email adapter returns unreachable error; assert report file persisted locally with retry metadata. Second run: adapter succeeds; assert persisted report is resent and local retry artifact is cleared/marked delivered.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.08,"Integration":0.74,"System":0.13,"Agentic":0.03,"Workflow":0.02}}]}
