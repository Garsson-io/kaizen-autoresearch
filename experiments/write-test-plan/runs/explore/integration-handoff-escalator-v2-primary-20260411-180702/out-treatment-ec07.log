ess run): restore email service and verify previously saved report is retried and delivered, then fallback artifact is marked sent/cleared.","plan_consistent":true,"plan_consistent_note":null,"level_probabilities":{"Unit":0.04,"Integration":0.23,"System":0.66,"Agentic":0.02,"Workflow":0.05}}]}
